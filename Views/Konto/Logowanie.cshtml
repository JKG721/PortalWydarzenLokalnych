<!-- strona logowania -->
@{
    ViewData["Title"] = "Logowanie";
}

<h2>Logowanie</h2>

<form method="post">
    <!--wyświetlanie bledow-->
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            @foreach (var blad in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <p>@blad.ErrorMessage</p>
            }
        </div>
    }

    <div class="mb-3">
        <label>Email</label>
        <input type="email" name="email" class="form-control" required />
    </div>

    <div class="mb-3">
        <label>Hasło</label>
        <input type="password" name="haslo" class="form-control" required />
    </div>

    <div class="mb-3">
        <input type="checkbox" name="zapamietaj" /> Zapamiętaj mnie
    </div>

    <button type="submit" class="btn btn-primary">Zaloguj się</button>
    <a href="/Konto/Rejestracja" class="btn btn-link">Nie mam konta</a>
</form>